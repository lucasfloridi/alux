/*
INSERT INTO SD3010 (D3_FILIAL,D3_COD,D3_TIPO,D3_TM,D3_UM,D3_CF,D3_CONTA,D3_OP,D3_QUANT,D3_CC,D3_LOCAL,D3_DOC,D3_EMISSAO,D3_GRUPO,D3_NUMSEQ,D3_USUARIO,D3_CHAVE,D3_IDENT,R_E_C_N_O_)
SELECT D3_FILIAL
,B1_COD D3_COD
,B1_TIPO D3_TIPO
,'503' D3_TM
,B1_UM D3_UM
,'RE0' D3_CF
,B1_CONTA D3_CONTA
,D3_OP
,CASE WHEN B1_UM='HR' THEN DATEDIFF(MINUTE,CONVERT(DATETIME,'00:00'),CONVERT(datetime,H6_TEMPO))/60.00 ELSE H6_QTDPROD END D3_QUANT
,B1_CC D3_CC
,B1_LOCPAD D3_LOCAL
,D3_DOC
,D3_EMISSAO
,B1_GRUPO D3_GRUPO
,D3_NUMSEQ
,D3_USUARIO
,'E0' D3_CHAVE
,D3_IDENT
,ROW_NUMBER() OVER(PARTITION BY D3_FILIAL ORDER BY D3_FILIAL)+(SELECT MAX(R_E_C_N_O_) FROM SD3010)
FROM SD3010 SD3
  INNER JOIN SH6010 SH6 ON SH6.D_E_L_E_T_='' AND H6_FILIAL=D3_FILIAL AND H6_OP=D3_OP AND H6_IDENT=D3_IDENT AND H6_TEMPO <'024:00'
  INNER JOIN SH1010 SH1 ON SH1.D_E_L_E_T_='' AND H1_CODIGO=H6_RECURSO 
  INNER JOIN SB1010 SB1 ON SB1.D_E_L_E_T_='' AND B1_TIPO IN ('GG','MO') AND B1_COD NOT LIKE 'MOD%'  AND B1_CCCUSTO='1'+SUBSTRING(H1_CCUSTO,2,5)
WHERE SD3.D_E_L_E_T_='' AND D3_TM='010' AND D3_FILIAL='0201' AND D3_ESTORNO<>'S'
AND D3_EMISSAO LIKE '202602%'
AND NOT EXISTS (SELECT 1 FROM SD3010 SD3E WHERE SD3.D_E_L_E_T_='' AND SD3E.D3_OP=SD3.D3_OP AND SD3E.D3_COD=SB1.B1_COD)

*/


//CR

/*
INSERT INTO SD3010 (D3_FILIAL,D3_COD,D3_TIPO,D3_TM,D3_UM,D3_CF,D3_CONTA,D3_OP,D3_QUANT,D3_CC,D3_LOCAL,D3_DOC,D3_EMISSAO,D3_GRUPO,D3_NUMSEQ,D3_USUARIO,D3_CHAVE,D3_IDENT,R_E_C_N_O_)
SELECT D3_FILIAL
,B1_COD D3_COD
,B1_TIPO D3_TIPO
,'503' D3_TM
,B1_UM D3_UM
,'RE0' D3_CF
,B1_CONTA D3_CONTA
,D3_OP
,D3_QUANT
,B1_CC D3_CC
,B1_LOCPAD D3_LOCAL
,D3_DOC
,D3_EMISSAO
,B1_GRUPO D3_GRUPO
,D3_NUMSEQ
,D3_USUARIO
,'E0' D3_CHAVE
,D3_IDENT
,ROW_NUMBER() OVER(PARTITION BY D3_FILIAL ORDER BY D3_FILIAL)+(SELECT MAX(R_E_C_N_O_) FROM SD3010)
FROM SD3010 SD3
  INNER JOIN SC2010 SC2 ON SC2.D_E_L_E_T_='' AND C2_NUM+C2_ITEM+C2_SEQUEN=D3_OP AND C2_FILIAL=D3_FILIAL AND C2_LOCAL='00'
  INNER JOIN SB1010 SB1 ON SB1.D_E_L_E_T_='' AND B1_TIPO IN ('GG','MO') AND B1_COD NOT LIKE 'MOD%'  AND B1_CCCUSTO='1CT001'
WHERE SD3.D_E_L_E_T_='' AND D3_TM='010' AND D3_FILIAL='0201' AND D3_ESTORNO<>'S'
AND D3_EMISSAO LIKE '202602%'
AND NOT EXISTS (SELECT 1 FROM SD3010 SD3E WHERE SD3.D_E_L_E_T_='' AND SD3E.D3_OP=SD3.D3_OP AND SD3E.D3_COD=SB1.B1_COD)
*/
